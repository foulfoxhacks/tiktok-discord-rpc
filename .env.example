# Your exact TikTok username (without the @)
TIKTOK_USERNAME=your_tiktok_username

# The Application ID from the Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_application_id

# The asset key of an image you uploaded under "Rich Presence -> Art Assets"
# in the Discord Developer Portal. Defaults to `tiktok_logo` if omitted.
DISCORD_LARGE_IMAGE_KEY=tiktok_logo
